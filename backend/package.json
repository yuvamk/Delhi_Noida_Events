{
  "name": "delhi-noida-events-backend",
  "version": "1.0.0",
  "description": "Backend API for Delhi-Noida Events Platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "reload": "pm2 reload dne-backend --update-env",
    "stop": "pm2 stop dne-backend",
    "logs": "pm2 logs dne-backend",
    "monit": "pm2 monit",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "seed": "ts-node src/scripts/seed.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.39.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/socket.io": "^3.0.2",
    "@types/uuid": "^11.0.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
