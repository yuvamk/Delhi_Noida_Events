# ─── BACKEND .env ─────────────────────────────────────────────
# Copy this to backend/.env and fill in your values

# MongoDB Atlas
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/delhi_noida_events

# JWT Secrets (generate: openssl rand -base64 64)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here

# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis (optional — caching is disabled if not set)
REDIS_URL=redis://localhost:6379

# Scraper API Key (shared secret between scraper and backend)
SCRAPER_API_KEY=your_scraper_api_key_here

# Email (optional — for newsletter/notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_specific_password

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── FRONTEND .env.local ──────────────────────────────────────
# Copy as frontend/.env.local

NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── SCRAPER .env ─────────────────────────────────────────────
# Copy as scraper/.env

BACKEND_API_URL=http://localhost:5000/api/v1
SCRAPER_API_KEY=your_scraper_api_key_here
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/delhi_noida_events

# ─── QUICK START ──────────────────────────────────────────────
# 1. Clone repo
# 2. Fill in values above
# 3. cd backend && npm install && npm run seed   (creates admin@gmail.com / admin@123)
# 4. cd backend && npm run dev
# 5. cd frontend && npm install && npm run dev
# 6. cd scraper && pip install -r requirements.txt && python main.py --once
